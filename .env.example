# ─── Data source ──────────────────────────────────────────────────────────
# Primary: edinetdb.jp (Cabocia Inc.) — daily-refreshed EDINET data + ratios
# Get your free key at: https://edinetdb.jp/developers/dashboard
EDINETDB_API_KEY=

# Optional: official 金融庁 EDINET API v2 (only used when --source=edinet flag is passed)
# Register at: https://disclosure2.edinet-fsa.go.jp/  →  ログイン  →  API キー発行
EDINET_API_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────
# https://supabase.com  →  New project  →  Project Settings  →  API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Use the Pooler (Transaction mode) URL — port 6543
DATABASE_URL=

# ─── Web ─────────────────────────────────────────────────────────────────
# Used by Next.js for OGP image full URLs and sitemap
NEXT_PUBLIC_SITE_URL=https://salary-ranking-jp.vercel.app
