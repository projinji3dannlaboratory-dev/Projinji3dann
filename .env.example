# ─── Data source ──────────────────────────────────────────────────────────
# Primary: edinetdb.jp (Cabocia Inc.) — daily-refreshed EDINET data + ratios
# Get your free key at: https://edinetdb.jp/developers/dashboard
EDINETDB_API_KEY=

# Optional: official 金融庁 EDINET API v2 (only used when --source=edinet flag is passed)
EDINET_API_KEY=

# ─── Supabase (optional) ─────────────────────────────────────────────────
# https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ─── Web ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://salary-ranking-jp.vercel.app

# ─── Site operator info (shown on /privacy, /terms, /contact, footer) ───
# Defaults are hard-coded in lib/site-config.ts to the verified operator
# (プロ人事３段 さとう). Override here only if running under a different brand.
NEXT_PUBLIC_SITE_OPERATOR=
NEXT_PUBLIC_SITE_OPERATOR_TITLE=
NEXT_PUBLIC_CONTACT_EMAIL=

# ─── Monetization & analytics (optional, both must be set per service) ──
# Google AdSense Publisher ID. Format: ca-pub-XXXXXXXXXXXXXXXX
# When set, AdSense script + ownership meta tag are emitted automatically.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Google Analytics 4 Measurement ID. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
